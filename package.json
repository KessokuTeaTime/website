{
  "packageManager": "pnpm@11.13.0",
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "serve": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "astro-i18n extract",
    "i18n:generate:pages": "astro-i18n generate:pages --purge",
    "i18n:generate:types": "astro-i18n generate:types",
    "i18n:sync": "npm run i18n:generate:pages && npm run i18n:generate:types"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/node": "^9.5.5",
    "@astrojs/vue": "^5.1.4",
    "@iconify/vue": "^5.0.1",
    "@types/lodash": "^4.17.24",
    "@vueuse/core": "^13.9.0",
    "@vueuse/sound": "^2.1.3",
    "astro": "^5.18.2",
    "camelcase-keys": "^9.1.3",
    "decamelcase-keys": "^1.1.1",
    "esbuild": "^0.25.12",
    "globals": "^17.7.0",
    "lodash": "^4.18.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "serve": "^14.2.6",
    "unified": "11.0.5",
    "unitflip": "^1.4.1",
    "vue": "^3.5.39",
    "vue-confetti-explosion": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@inlang/paraglide-js": "^2.22.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.100.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
